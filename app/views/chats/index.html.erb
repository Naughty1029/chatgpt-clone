<% 
messages = [
  { role: "user", text: "こんにちは", parts: [{ type: "text", content: "こんにちは" }] },
  { role: "assistant", text: "こんにちは！何かお手伝いできることはありますか？", parts: [{ type: "text", content: "こんにちは！何かお手伝いできることはありますか？" }] }
]
%>

<div class="flex flex-col mx-auto px-4 w-full md:max-w-3xl h-svh">
  <div class="grow pt-4 mb-4 overflow-y-auto min-h-0">
    <div class="flex flex-col min-w-0 gap-6">
    <% messages.each do |message| %>
      <% message[:parts].each do |part| %>
        <% if part[:type] == "text" %>
          <p class="<%= 'message-user-bubble' if message[:role] == 'user' %>"><%= part[:content] %></p>
        <% end %>
      <% end %>
    <% end %>
    </div>  
  </div>
  <form action="*" accept-charset="UTF-8" method="post" class="flex mx-auto bg-background pb-4 md:pb-6 gap-2 w-full">
    <input type="hidden" name="authenticity_token" value="[YOUR_CSRF_TOKEN_HERE]">
    <div class="relative flex w-full gap-4">
      <textarea id="input" name="input" autofocus="autofocus" rows="2" class="w-full border border-input bg-background px-3 py-2 md:text-sm resize-none rounded-2xl bg-muted pb-10 border-zinc-300 dark:border-zinc-700 focus:outline-none" placeholder="質問してみましょう"></textarea>
      <div class="absolute bottom-0  right-0 p-2 w-fit flex flex-row justify-end">
        <button name="button" type="submit" class="rounded-full p-1.5 h-fit border dark:border-zinc-600">
          <%= image_tag "arrowup.svg" %>
        </button>
      </div>
    </div>
  </form>
</div>